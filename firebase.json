{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": [
    {
      "database": "biogrid",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "BioGrid3",
        "supportEmail": "michswo@gmail.com",
        "authorizedRedirectUris": ["http://localhost"]
      }
    }
  }
}
